# Netlify / Lovable — Cache headers
# Los assets con hash son inmutables (Vite los renombra en cada build)

/assets/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/images/*
  Cache-Control: public, max-age=31536000, immutable

/logo*.webp
  Cache-Control: public, max-age=31536000, immutable

/logo*.png
  Cache-Control: public, max-age=604800

/~flock.js
  Cache-Control: public, max-age=31536000, immutable

# Seguridad global
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY

# HTML y rutas SPA — siempre revalidar (nunca cachear el shell)
/
  Cache-Control: public, max-age=0, must-revalidate

/*.html
  Cache-Control: public, max-age=0, must-revalidate
