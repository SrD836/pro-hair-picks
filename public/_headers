# Netlify / Cloudflare — Cache headers
# Los assets con hash de Vite son inmutables: max-age=1 año
# CDN-Cache-Control controla el caché de Cloudflare independientemente del browser

/assets/*
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: max-age=31536000
  X-Content-Type-Options: nosniff

/images/*
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: max-age=31536000

/logo*.webp
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: max-age=31536000

/logo*.png
  Cache-Control: public, max-age=604800
  CDN-Cache-Control: max-age=604800

/*.webp
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: max-age=31536000

/~flock.js
  Cache-Control: public, max-age=31536000, immutable

# Seguridad global
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN

# HTML y rutas SPA — siempre revalidar
/
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: no-cache

/*.html
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: no-cache
